<UserControl
    x:Class="ActivityManagement.App.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <Grid x:Name="Root" Padding="10,4" ColumnDefinitions="Auto,*" ColumnSpacing="10" Background="Transparent" PointerPressed="Root_PointerPressed">
        <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="CountText" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="0" />
            <TextBlock Text="open" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
            <TextBlock x:Name="NextTitleText" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="NextDueText" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</UserControl>
