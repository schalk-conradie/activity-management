<Window
    x:Class="ActivityManagement.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ActivityManagement.App"
    Title="Activity Management">

    <Grid Padding="16" RowSpacing="12" RowDefinitions="Auto,Auto,*,Auto" MinWidth="420" MinHeight="520">
        <StackPanel Spacing="2">
            <TextBlock x:Name="SummaryText" FontSize="20" FontWeight="SemiBold" Text="Tasks" />
            <TextBlock x:Name="NextDueText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="TitleBox" PlaceholderText="New task" />
            <Button Grid.Column="1" Click="AddTask_Click" ToolTipService.ToolTip="Create task">
                <SymbolIcon Symbol="Add" />
            </Button>
        </Grid>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <CalendarDatePicker x:Name="DueDatePicker" PlaceholderText="Due date" />
                <TimePicker x:Name="DueTimePicker" Grid.Column="1" ClockIdentifier="24HourClock" />
                <ComboBox x:Name="PriorityBox" Grid.Column="2" Width="112" SelectedIndex="1">
                    <ComboBoxItem Content="Low" Tag="low" />
                    <ComboBoxItem Content="Normal" Tag="normal" />
                    <ComboBoxItem Content="High" Tag="high" />
                    <ComboBoxItem Content="Urgent" Tag="urgent" />
                </ComboBox>
            </Grid>

            <ListView x:Name="TasksList" Grid.Row="1" ItemsSource="{x:Bind Tasks, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:TaskRow">
                        <Grid Padding="0,8" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind Metadata}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Button Tag="{x:Bind Id}" Click="OpenSource_Click" IsEnabled="{x:Bind HasExternalReference}" ToolTipService.ToolTip="Open source item">
                                    <SymbolIcon Symbol="Link" />
                                </Button>
                                <Button Tag="{x:Bind Id}" Click="MarkDone_Click" ToolTipService.ToolTip="Mark done">
                                    <SymbolIcon Symbol="Accept" />
                                </Button>
                                <Button Tag="{x:Bind Id}" Click="CancelTask_Click" ToolTipService.ToolTip="Cancel task">
                                    <SymbolIcon Symbol="Cancel" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
    </Grid>
</Window>
